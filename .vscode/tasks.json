{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run NeuroGuard Backend",
			"type": "shell",
			"command": "cd backend && uvicorn main:app --host 0.0.0.0 --port 8000 --reload",
			"isBackground": true,
			"group": "build"
		},
		{
			"label": "Run NeuroGuard Frontend",
			"type": "shell",
			"command": "cd frontend && npm run dev",
			"isBackground": true,
			"group": "build"
		},
		{
			"label": "Run NeuroGuard Backend Python",
			"type": "shell",
			"command": "cd backend && python3 -m uvicorn main:app --host 0.0.0.0 --port 8000 --reload",
			"isBackground": true,
			"group": "build"
		}
	]
}